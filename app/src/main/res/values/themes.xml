<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App Theme -->
    <style name="Theme.EasyBoardingFinder" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryDark">@color/primary_blue_dark</item>
        <item name="colorAccent">@color/accent_orange</item>
        <item name="android:windowBackground">@color/background_white</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:fontFamily">sans-serif</item>
        <!-- Material card defaults -->
        <item name="materialCardViewStyle">@style/AppCardViewStyle</item>
    </style>

    <!-- Circle Image Shape -->
    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.EasyBoardingFinder.Splash" parent="Theme.EasyBoardingFinder">
        <item name="android:windowBackground">@color/splash_blue</item>
        <item name="android:statusBarColor">@color/splash_blue</item>
        <item name="android:navigationBarColor">@color/splash_blue</item>
    </style>

    <!-- Auth Theme (for login, register, etc.) -->
    <style name="Theme.EasyBoardingFinder.Auth" parent="Theme.EasyBoardingFinder">
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <!-- Input Field Style -->
    <style name="InputFieldStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/input_height</item>
        <item name="android:background">@drawable/bg_input_field</item>
        <item name="android:paddingStart">48dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
    </style>

    <!-- Primary Button Style -->
    <style name="PrimaryButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Outline Button Style -->
    <style name="OutlineButtonStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:background">@drawable/bg_button_outline</item>
        <item name="android:textColor">@color/primary_blue</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Global Card Style - Figma-aligned: soft shadow, white surface, rounded corners -->
    <style name="AppCardViewStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#F1F5F9</item>
    </style>
</resources>
