<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background stripe pattern - diagonal blue & white stripes -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/stripe_blue_2" />
        </shape>
    </item>
    <!-- Stripe 1 -->
    <item
        android:left="-100dp"
        android:top="-40dp"
        android:right="-100dp">
        <rotate
            android:fromDegrees="-45"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <solid android:color="@color/stripe_blue_3" />
                <size android:height="30dp" />
            </shape>
        </rotate>
    </item>
</layer-list>
