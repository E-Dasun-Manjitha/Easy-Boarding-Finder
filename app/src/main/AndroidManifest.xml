<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".EasyBoardingFinderApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EasyBoardingFinder"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Google Maps API Key (Development Mode) -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- ─── Splash Screen ─── -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.EasyBoardingFinder.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ─── Auth Screens ─── -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.VerifyEmailActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.CreateNewPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.PasswordChangedActivity"
            android:exported="false" />

        <!-- ─── Main Screen ─── -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ─── Property Screens ─── -->
        <activity
            android:name=".ui.property.AddPropertyActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
            
        <activity
            android:name=".ui.property.PropertyDetailActivity"
            android:exported="false" />

        <!-- ─── Utility Screens ─── -->
        <activity
            android:name=".ui.main.MapPickerActivity"
            android:exported="false" />

        <!-- ─── Share Person CRUD ─── -->
        <activity
            android:name=".ui.shareperson.AddSharePersonActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.shareperson.SharePersonDetailActivity"
            android:exported="false" />

        <!-- ─── Furniture CRUD ─── -->
        <activity
            android:name=".ui.furniture.AddFurnitureActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.furniture.FurnitureDetailActivity"
            android:exported="false" />

        <!-- ─── Contact Us CRUD ─── -->
        <activity
            android:name=".ui.contact.AddContactActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ─── Chat Screens ─── -->
        <activity
            android:name=".ui.contact.ChatListActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.contact.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
